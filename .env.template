# PhoneBuddy — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Twilio (get from twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Anthropic (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ElevenLabs (get from elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure Speech (get from portal.azure.com — Cognitive Services)
AZURE_SPEECH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_SPEECH_REGION=westus

# Config path (default: config/user-profile.yaml)
PHONEBUDDY_CONFIG=config/user-profile.yaml

# Public URL (set by ngrok or Cloudflare Tunnel — used for Twilio webhook auto-config)
PUBLIC_URL=https://your-ngrok-or-cloudflare-url.com
